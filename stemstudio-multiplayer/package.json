{
  "private": true,
  "name": "my-app",
  "version": "1.0.0",
  "type": "module",
  "description": "npm init template for bootstrapping an empty Colyseus project",
  "main": "build/index.js",
  "scripts": {
    "start": "tsx watch src/index.ts",
    "launch": "node build/src/index.js",
    "launch:d": "node build/index.js",
    "launch-dev": "node --trace-warnings --inspect build/src/index.js",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "npm run clean && npm run typecheck && tsc",
    "clean": "node -e \"require('node:fs').rmSync('build', { recursive: true, force: true })\"",
    "test": "mocha -r tsx test/**_test.ts --exit --timeout 15000",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@colyseus/loadtest": "^0.15.8",
    "@colyseus/testing": "^0.15.4",
    "@types/chai": "^5.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.10",
    "@types/pako": "^2.0.4",
    "@types/sinon": "^17.0.4",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "chai": "^6.2.0",
    "eslint": "^9.37.0",
    "eslint-plugin-import": "^2.32.0",
    "mocha": "^11.7.4",
    "rimraf": "^6.0.1",
    "sinon": "^21.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "@colyseus/clock": "^1.0.0",
    "@colyseus/cloud": "^1.0.12",
    "@colyseus/monitor": "^0.15.8",
    "@colyseus/playground": "^0.15.17",
    "@colyseus/redis-presence": "^0.15.6",
    "@colyseus/schema": "^2.0.36",
    "@colyseus/timer": "^1.0.1",
    "@colyseus/tools": "^0.15.49",
    "@colyseus/ws-transport": "^0.15.3",
    "@types/bad-words": "^3.0.3",
    "ammo.js": "^0.0.10",
    "axios": "^1.7.2",
    "bad-words": "^4.0.0",
    "colyseus": "^0.15.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "mongoose": "^8.15.1",
    "pako": "^2.1.0",
    "three": "^0.167.1",
    "ws": "^8.18.3",
    "y-mongodb-provider": "^0.2.1",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27"
  },
  "optionalDependencies": {
    "firebase-admin": "^13.4.0"
  }
}
