# StemStudio multiplayer sidecar — sample environment.
#
# Copy to `.env`. The server reads this at startup.

# Server port the Colyseus transport binds to.
PORT=2567

# Upstream game-services API the server calls for scene/admin lookups.
# Leave at the default for local dev.
API_BASE_URL=http://localhost:2020

# Environment (development / production).
NODE_ENV=development

# Public hostname for clients to reach this server. Only needed when
# deploying behind a reverse proxy / on a public domain.
FQDN_HOSTNAME=

# ─── MongoDB (optional) ─────────────────────────────────────────────────────
# In-memory state is used by default. Set MONGO_CONNECTION to persist
# private-room data across restarts.
# MONGO_CONNECTION=mongodb://127.0.0.1:27017
# MONGO_DB=ShadowEditor

# ─── Redis (optional, for horizontal scaling) ───────────────────────────────
# REDIS_ENABLELD=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USR=
# REDIS_CLUSTERNODES=

# ─── Firebase auth (optional) ───────────────────────────────────────────────
# When set, the server verifies client tokens via Firebase Admin SDK. When
# unset, auth verification is skipped — fine for single-machine / local dev,
# not recommended for public deployments.
# FIREBASE_CONFIG_PATH=./firebase-admin.json
# FIREBASE_WEB_API_KEY=
