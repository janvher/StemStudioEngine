        "startOnTrigger": {
            "name": "Start On Trigger",
            "type": "boolean",
            "default": false,
            "description": "When enabled, the visual effect only plays when activated by a Trigger behavior instead of starting automatically."
        },
        "triggerOnAdded": {
            "name": "Trigger on Added to Game",
            "type": "boolean",
            "default": false,
            "description": "If true, the visual effect will be triggered when the object is added"
        },
        "triggerByParent": {
