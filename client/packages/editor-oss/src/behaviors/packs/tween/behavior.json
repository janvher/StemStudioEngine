                    "value": "quintOut"
                },
                {
                    "label": "Quint In Out",
                    "value": "quintInOut"
                },
                {
                    "label": "Sine In",
                    "value": "sineIn"
                },
                {
                    "label": "Sine Out",
                    "value": "sineOut"
                },
                {
                    "label": "Sine In Out",
                    "value": "sineInOut"
                },
                {
                    "label": "Back In",
                    "value": "backIn"
                },
                {
                    "label": "Back Out",
                    "value": "backOut"
                },
                {
                    "label": "Back In Out",
                    "value": "backInOut"
                },
                {
                    "label": "Circ In",
                    "value": "circIn"
                },
                {
                    "label": "Circ Out",
                    "value": "circOut"
                },
                {
                    "label": "Circ In Out",
