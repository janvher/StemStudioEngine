        "loopMode": {
            "name": "Loop Mode",
            "type": "enum",
            "options": [
                {
                    "label": "None",
                    "value": "Play Once"
                },
                {
                    "label": "Repeat",
                    "value": "Repeat"
                },
                {
                    "label": "Mirror",
                    "value": "Loop"
                }
            ],
            "default": "Loop",
            "description": "Determines how the animation repeats: None plays once, Repeat restarts from the beginning, and Mirror plays forward then backward."
        }
