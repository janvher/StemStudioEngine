                    "value": "quadOut"
                },
                {
                    "label": "Quad In Out",
                    "value": "quadInOut"
                },
                {
                    "label": "Cubic In",
                    "value": "cubicIn"
                },
                {
                    "label": "Cubic Out",
                    "value": "cubicOut"
                },
                {
                    "label": "Cubic In Out",
                    "value": "cubicInOut"
                },
                {
                    "label": "Quart In",
                    "value": "quartIn"
                },
                {
                    "label": "Quart Out",
