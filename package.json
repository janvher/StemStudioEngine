{
  "name": "stemstudio-oss",
  "version": "0.7.3",
  "private": false,
  "license": "MIT",
  "type": "module",
  "description": "Open-source build of StemStudio — browser-based 3D sandbox editor and runtime. MIT-licensed.",
  "author": "StemStudio contributors",
  "homepage": "https://github.com/Stem-Studio/Engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stem-Studio/Engine.git"
  },
  "bugs": {
    "url": "https://github.com/Stem-Studio/Engine/issues"
  },
  "keywords": [
    "3d",
    "editor",
    "engine",
    "threejs",
    "game-engine",
    "webgl",
    "studio"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n vite,ai,mp -c blue,green,yellow \"BUILD_MODE=oss bunx --bun vite dev\" \"cd server && BUILD_MODE=oss go run -tags oss ./cmd/ai-server serve\" \"cd stemstudio-multiplayer && BUILD_MODE=oss npm start\"",
    "dev:editor": "BUILD_MODE=oss bunx --bun vite dev",
    "dev:ai": "cd server && BUILD_MODE=oss go run -tags oss ./cmd/ai-server serve",
    "dev:mp": "cd stemstudio-multiplayer && npm start",
    "build": "BUILD_MODE=oss bunx --bun vite --emptyOutDir build && bun scripts/copy.js",
    "build:ai-server": "cd server && go build -tags oss -buildvcs=false -trimpath -o ../build/server/stemstudio-ai-server ./cmd/ai-server",
    "typecheck": "cd client && bunx tsc --noEmit",
    "lint": "cd client && bunx eslint packages",
    "lint:oss-boundary": "cd client && eslint --config eslint.boundary.cjs --no-inline-config --no-warn-ignored --quiet 'packages/editor-oss/src/**/*.{ts,tsx}'",
    "test": "BUILD_MODE=oss bunx --bun vitest run",
    "test:e2e": "node scripts/playwright/oss-smoke.mjs",
    "test:e2e:site": "node scripts/playwright/site-deploy-routing.mjs && node scripts/playwright/site-landing.mjs && node scripts/playwright/site-docs.mjs && node scripts/playwright/site-nav.mjs && node scripts/playwright/site-playground.mjs",
    "test:e2e:site:routing": "node scripts/playwright/site-deploy-routing.mjs",
    "deploy": "./scripts/deploy.sh",
    "deploy:all": "./scripts/deploy.sh all",
    "deploy:cloudflare": "./scripts/deploy.sh cloudflare",
    "deploy:render": "./scripts/deploy.sh render",
    "deploy:local": "./scripts/deploy.sh local-basic",
    "deploy:local:full": "./scripts/deploy.sh local-full",
    "deploy:local:down": "./scripts/deploy.sh down",
    "docker:build": "docker compose build",
    "docker:build:full": "docker compose -f docker-compose.full.yml build",
    "docker:up": "docker compose up -d",
    "docker:up:full": "docker compose -f docker-compose.full.yml up -d",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down --remove-orphans && docker compose -f docker-compose.full.yml down --remove-orphans",
    "postinstall": "bun scripts/copy-draco.js && (cd stemstudio-multiplayer && npm install) && (cd stemstudio-copilot && bun install)"
  },
