{
  "name": "ai-3d-sandbox-copilot",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "node scripts/patch-sdk.mjs",
    "patch:sdk": "node scripts/patch-sdk.mjs",
    "patch:sdk:force": "FORCE_PATCH=1 node scripts/patch-sdk.mjs",
    "sync:typefiles": "bash scripts/sync_typefiles.sh",
    "sync:typefiles:strict": "STRICT_TYPEFILES=1 bash scripts/sync_typefiles.sh",
    "extract:types": "node scripts/extract-stem-types.cjs",
    "validate:code": "node scripts/validate-stem-code.cjs",
    "generate": "bun run sync:typefiles && bun run extract:types",
    "generate:strict": "STRICT_TYPEFILES=1 bun run sync:typefiles && bun run extract:types",
    "generate:types-only": "bun run extract:types",
    "build": "bun run sync:typefiles && bun run extract:types && tsc",
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "cli": "bun src/standalone/main.ts",
    "skills": "bun src/standalone/list-skills.ts",
    "skills:run": "bun src/standalone/skills-runner.ts",
    "acp:test:local": "bun src/server/cli/client.ts local",
    "acp:test:ws": "bun src/server/cli/client.ts websocket",
    "lint": "eslint src/",
    "test": "bun test src/__tests__/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@ai-sdk/anthropic": "^3.0.53",
    "@ai-sdk/google": "^3.0.36",
    "@ai-sdk/openai": "^3.0.39",
    "@zed-industries/codex-acp": "^0.13.0",
    "ai": "^6.0.108",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "json-rpc-protocol": "^0.13.2",
    "mcp-express-adapter": "^1.2.2",
    "multiplex": "^6.7.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "websocket-stream": "^5.5.2",
    "ws": "^8.19.0",
    "zhipu-ai-provider": "^0.2.2",
    "zod": "^4.3.6",
    "@ni2khanna/claude-agent-acp": "^0.23.2"
  },
  "optionalDependencies": {
    "firebase-admin": "^13.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-ws": "^3.0.6",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
