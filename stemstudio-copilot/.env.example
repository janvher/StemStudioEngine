# =============================================================================
# AI Provider Configuration
# =============================================================================

# Provider selection (default: anthropic)
# Options: anthropic, openai, codex, google, zhipu, minimax
AI_PROVIDER=anthropic

# Model override (optional — each provider has a sensible default)
# Examples: standalone-sonnet-4-5-20250929, gpt-4o, gpt-5-codex, gemini-2.0-flash, glm-4, minimax-m2
# AI_MODEL=

# Codex model override for ACP `/codex` route (default: gpt-5-codex)
# CODEX_MODEL=gpt-5-codex

# Fallback chain (comma-separated, tried in order when primary provider fails)
# AI_FALLBACK_PROVIDERS=openai,google

# Agent mode for `src/standalone/main.ts`:
# - standalone: use Claude Agent SDK flow (default)
# - shared: use shared `/api/vercel-rest` provider-agnostic flow
# AI_AGENT_MODE=standalone

# Enable shared provider-agnostic REST endpoint `/api/vercel-rest/*`
# Set to "true" to mount route in server
# SUPPORT_VERCEL_AI_SDK=false

# Claude code config folder
# If not set it defaults to $HOME/.claude
# CLAUDE_CONFIG_FOLDER=~/.claude

# Claude launch folder
# $CLAUDE_USER_FOLDER/<userId> is set as CWD
# CLAUDE_USER_FOLDER=/tmp/studio-agent

# =============================================================================
# Provider API Keys (at least one required)
# =============================================================================

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# OpenAI Codex (optional, defaults to OPENAI_API_KEY when omitted)
# OPENAI_CODEX_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=

# Zhipu GLM — https://open.bigmodel.cn/
# GLM_API_KEY=

# MiniMax — https://platform.minimax.io/
# MINIMAX_API_KEY=

# =============================================================================
# Server Configuration
# =============================================================================

# REST API Server Port (default: 3000)
PORT=3000

# Studio API host override for Docker/K8s (default: http://localhost:${PORT})
# STUDIO_API_HOST=http://localhost:3000

# Studio session ID (optional — can also be passed per-request)
# STUDIO_SESSION_ID=

# Base URL used by Python skill scripts in `ai/claude/skills/*/scripts/*.py`
# (server-side tools use STUDIO_API_HOST instead)
# API_SERVER_BASE_URL=http://localhost:3000

# =============================================================================
# Agent Thinking (Shared `/api/vercel-rest` flow)
# =============================================================================

# Enable/disable two-phase thinking mode.
# Default behavior when unset: enabled for anthropic, disabled otherwise.
# AI_THINKING_ENABLED=true

# Thinking model override (default: claude-opus-4-6)
# AI_THINKING_MODEL=claude-opus-4-6

# Thinking budget tokens, 0 = adaptive/default.
# AI_THINKING_BUDGET=0

# =============================================================================
# Web Research Tooling (Shared `/api/vercel-rest` flow)
# =============================================================================

# Enable external web research tools.
# WEB_RESEARCH_ENABLED=false

# Limit number of search operations per request (default is code-defined)
# WEB_RESEARCH_MAX_SEARCHES=3

# Limit number of fetch operations per request (default is code-defined)
# WEB_RESEARCH_MAX_FETCHES=5

# =============================================================================
# Firebase Authentication
# =============================================================================

# Firebase Admin SDK credentials (required for authentication)
# Path to a Firebase service account JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# =============================================================================
# Logging
# =============================================================================

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Log format: json for structured JSON lines, default for human-readable
# LOG_FORMAT=json

# =============================================================================
# Session Backup (S3-mounted filesystem)
# =============================================================================

# Enable periodic session backup to a mounted S3 filesystem (default: false)
# BACKUP_FS_ENABLED=false

# Path to the mounted S3 bucket (required when BACKUP_FS_ENABLED=true)
# BACKUP_FS_PATH=/mnt/s3-backup

# Backup interval in milliseconds (default: 300000 = 5 minutes)
# BACKUP_INTERVAL_MS=300000
